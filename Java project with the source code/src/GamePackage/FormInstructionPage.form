                <Component class="javax.swing.JLabel" name="lblins1">
                  <Properties>
                    <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                      <Font name="Sitka Text" size="14" style="3"/>
                    </Property>
                    <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;body style=&apos;width: 245px&apos;&gt;1.&#x9;The game is played on a grid of squares.&lt;/body&gt;&lt;/html&gt;"/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="lblins2">
                  <Properties>
                    <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                      <Font name="Sitka Text" size="14" style="3"/>
                    </Property>
                    <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;body style=&apos;width: 245px&apos;&gt;2.&#x9;Each square contains a number.&lt;/body&gt;&lt;/html&gt;"/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="lblins3">
                  <Properties>
                    <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                      <Font name="Sitka Text" size="14" style="3"/>
                    </Property>
                    <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;body style=&apos;width: 245px&apos;&gt;3.&#x9;The goal of the game is to rearrange &lt;br&gt;     the tiles like the below  image so that &lt;br&gt;     the grid is in numerical order, starting&lt;br&gt; from the top left corner and working &lt;br&gt; your way down each row.&lt;/body&gt;&lt;/html&gt;"/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="lblins4">
                  <Properties>
                    <Property name="icon" type="javax.swing.Icon" editor="org.netbeans.modules.form.editors2.IconEditor">
                      <Image iconType="3" name="/GamePackage/arrangedpuzzle.png"/>
                    </Property>
                    <Property name="text" type="java.lang.String" value="&#xa;"/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="lblins5">
                  <Properties>
                    <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                      <Font name="Sitka Text" size="14" style="3"/>
                    </Property>
                    <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;body style=&apos;width: 245px&apos;&gt;4.&#x9;You can move the tiles by clicking on them. The tile will slide to the empty &lt;br&gt;space next to it.&lt;/body&gt;&lt;/html&gt;"/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="lblins6">
                  <Properties>
                    <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                      <Font name="Sitka Text" size="14" style="3"/>
                    </Property>
                    <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;body style=&apos;width: 245px&apos;&gt;5.&#x9;Only one tile can be moved at a time.&lt;/body&gt;&lt;/html&gt;"/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="lblins7">
                  <Properties>
                    <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                      <Font name="Sitka Text" size="14" style="3"/>
                    </Property>
                    <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;body style=&apos;width: 245px&apos;&gt;6.&#x9;You have one hour to solve the puzzle.&lt;/body&gt;&lt;/html&gt;"/>
                  </Properties>
                </Component>
